    "code_generation_enabled": false,
    "rag_enabled": false,
    "notifications_enabled": false,
    "audit_logging_enabled": false
  },
  "hooks": {
    "auto_extraction_hook": {
      "enabled": true,
      "priority": 100,
      "description": "Automatically extract data from documents",
      "trigger_events": [
        "document.uploaded",
        "document.updated"
      ],
      "max_execution_time_seconds": 300,
      "timeout_behavior": "log_and_continue"
    },
    "validation_hook": {
      "enabled": true,
      "priority": 90,
      "description": "Validate extracted data quality",
      "trigger_events": [
        "extraction.completed"
      ],
      "max_execution_time_seconds": 60,
      "timeout_behavior": "log_and_continue"
    },
    "notification_hook": {
      "enabled": true,
      "priority": 50,
      "description": "Send notifications on important events",
      "trigger_events": [
        "document.uploaded",
        "extraction.completed",
        "task.status_changed"
      ],
      "max_execution_time_seconds": 30,
      "timeout_behavior": "log_and_continue"
    },
    "audit_logging_hook": {
      "enabled": true,
      "priority": 10,
      "description": "Log all operations for audit trail",
      "trigger_events": [
        "document.uploaded",
        "document.deleted",
        "extraction.completed",
        "code.created",
        "code.deleted",
        "task.status_changed"
      ],
      "max_execution_time_seconds": 10,
      "timeout_behavior": "log_and_continue"
    }
  },
